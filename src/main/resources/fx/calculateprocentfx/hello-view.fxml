<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER_LEFT" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fx.calculateprocentfx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <FlowPane prefWidth="0.0">
      <children>
         <Label fx:id="sumNow" text="Сумма в чеке">
            <FlowPane.margin>
               <Insets right="10.0" />
            </FlowPane.margin>
         </Label>
         <TextField fx:id="inputText" prefHeight="26.0" prefWidth="88.0">
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
            <FlowPane.margin>
               <Insets right="10.0" />
            </FlowPane.margin></TextField>
         <Label text="Рублей" />
      </children>
   </FlowPane>
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
          <Button onAction="#onClickProcent15" text="Procent 15%">
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin></Button>

          <Label fx:id="procent15" />
      </children>
   </HBox>
   <CheckBox fx:id="checkBox" alignment="CENTER" mnemonicParsing="false" onAction="#onChoiceProcent" selected="true" text="Choice procent" />
   <HBox layoutX="30.0" layoutY="30.0" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="button10" onAction="#onClickProcent10" text="Procent 10%">
            <opaqueInsets>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </opaqueInsets>
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin></Button>
         <Label fx:id="procent10" />
      </children>
   </HBox>
   <HBox layoutX="30.0" layoutY="150.0" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button onAction="#onClickProcent3" text="Procent 3%">
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin></Button>
         <Label fx:id="procent3" />
      </children>
   </HBox>
</VBox>
